FROM docker.io/library/debian:bookworm-slim

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    findutils \
    gawk \
    git \
    grep \
    iproute2 \
    procps \
    rsync \
    util-linux \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /lab

CMD ["/bin/bash"]
